---
import { Send } from '@lucide/astro';
---

<section class="py-24 bg-slate-50 border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
      <div class="grid lg:grid-cols-2">

        <!-- Contact Info / Copy -->
        <div class="p-12 lg:p-16 bg-blue-600 text-white flex flex-col justify-between">
          <div>
            <h2 class="text-3xl font-bold mb-6">¿Listo para optimizar tu riego?</h2>
            <p class="text-blue-100 text-lg mb-8 leading-relaxed">
              Déjanos tus datos y un especialista en agrotecnología te contactará en menos de 24 horas para evaluar la viabilidad en tus embalses.
            </p>

            <div class="space-y-6">
              <div class="flex items-center gap-4 text-blue-100">
                <div class="w-12 h-12 rounded-full bg-blue-500/50 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-blue-200">Email Directo</p>
                  <p class="font-semibold">agronomia@aquasenseiot.com</p>
                </div>
              </div>
              <div class="flex items-center gap-4 text-blue-100">
                <div class="w-12 h-12 rounded-full bg-blue-500/50 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-blue-200">Soporte y Ventas</p>
                  <p class="font-semibold">+56 9 1234 5678</p>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-12 opacity-50">
            <svg class="w-32 h-32 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 21.5C12 21.5 3 14.5 3 8.5C3 5.46243 5.46243 3 8.5 3C10.2741 3 11.8517 3.84439 12 5.1558C12.1483 3.84439 13.7259 3 15.5 3C18.5376 3 21 5.46243 21 8.5C21 14.5 12 21.5 12 21.5Z" />
            </svg>
          </div>
        </div>

        <!-- Form -->
        <div class="p-12 lg:p-16">
          <form class="space-y-6">
            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2 col-span-2 sm:col-span-1">
                <label for="name" class="text-sm font-medium text-slate-700">Nombre completo</label>
                <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" placeholder="Ej. Juan Pérez" />
              </div>
              <div class="space-y-2 col-span-2 sm:col-span-1">
                <label for="company" class="text-sm font-medium text-slate-700">Empresa / Fundo</label>
                <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" placeholder="Ej. Agrícola El Sol" />
              </div>
            </div>

            <div class="space-y-2">
              <label for="email" class="text-sm font-medium text-slate-700">Email laboral</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" placeholder="juan@agricola.com" />
            </div>

            <div class="space-y-2">
              <label for="message" class="text-sm font-medium text-slate-700">Mensaje o Detalles de tu proyecto</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none" placeholder="Tengo 3 embalses de 10.000m3 para riego de arándanos..."></textarea>
            </div>

            <button type="submit" class="w-full flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white py-4 rounded-xl font-bold transition-all shadow-md">
              <Send class="h-4 w-4" />
              Solicitar Contacto
            </button>
            <p class="text-xs text-center text-slate-500 mt-4">
              Al enviar este formulario aceptas nuestra política de privacidad.
            </p>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>
