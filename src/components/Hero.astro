---
import {
  ArrowRight,
  PlayCircle,
  BarChart3,
  Droplets,
  Thermometer,
  Wifi,
} from "@lucide/astro";
import hero_main_image from "../assets/hero/hero_main_image.webp";
---

<section
  class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-slate-50"
>
  <!-- Background Decor -->
  <div
    class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 opacity-20 pointer-events-none"
  >
    <div
      class="w-[800px] h-[800px] rounded-full bg-gradient-to-br from-blue-400 to-emerald-200 blur-3xl"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left Column: Text -->
      <div class="max-w-2xl">
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-100/50 border border-blue-200 text-blue-700 font-medium text-sm mb-6"
        >
          <span class="flex h-2 w-2 rounded-full bg-blue-600 animate-pulse"
          ></span>
          Monitoreo IoT en tiempo real
        </div>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-[1.1] mb-6"
        >
          Protege tus cultivos optimizando la calidad de tu <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-emerald-500"
            >agua en tiempo real</span
          >
        </h1>
        <p class="text-lg text-slate-600 mb-8 leading-relaxed">
          Boya inteligente para embalses agrícolas. Asegura el pH, conductividad
          y temperatura perfecta para tus cultivos, previniendo pérdidas antes
          de que ocurran.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/#contact"
            class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-semibold shadow-lg shadow-blue-600/20 transition-all hover:-translate-y-0.5"
          >
            Cotizar ahora
            <ArrowRight class="h-5 w-5" />
          </a>
          <button
            class="flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 px-8 py-4 rounded-xl font-semibold shadow-sm transition-all hover:-translate-y-0.5"
          >
            <PlayCircle class="h-5 w-5 text-blue-600" />
            Ver Demo
          </button>
        </div>

        <div class="mt-10 flex items-center gap-6 text-sm text-slate-500"></div>
      </div>

      <!-- Right Column: Visual -->
      <div class="relative mx-auto w-full max-w-lg lg:max-w-none">
        <!-- Main Image -->
        <div
          class="relative rounded-2xl overflow-hidden shadow-2xl shadow-blue-900/10 border border-slate-200 bg-white"
        >
          <img
            src={hero_main_image.src}
            alt="Boya inteligente en embalse"
            class="w-full h-[500px] object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>

        <!-- Floating Dashboard Element -->
        <div
          class="absolute -bottom-6 -left-3 sm:-left-6 bg-white p-5 rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-100 w-[280px]"
          style="animation-duration: 3s;"
        >
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-900 text-sm">
              Estado del Embalse
            </h3>
            <span
              class="flex items-center gap-1 text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full"
            >
              <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
              Óptimo
            </span>
          </div>

          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="p-1.5 bg-blue-50 rounded-lg text-blue-600">
                  <Droplets class="h-4 w-4" />
                </div>
                <span class="text-sm text-slate-600">pH</span>
              </div>
              <span class="font-semibold text-slate-900">6.2</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="p-1.5 bg-purple-50 rounded-lg text-purple-600">
                  <BarChart3 class="h-4 w-4" />
                </div>
                <span class="text-sm text-slate-600">CE (mS/cm)</span>
              </div>
              <span class="font-semibold text-slate-900">1.8</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="p-1.5 bg-orange-50 rounded-lg text-orange-600">
                  <Thermometer class="h-4 w-4" />
                </div>
                <span class="text-sm text-slate-600">Temp</span>
              </div>
              <span class="font-semibold text-slate-900">18°C</span>
            </div>
          </div>
        </div>

        <!-- Floating connection badge -->
        <div
          class="absolute top-6 -right-6 bg-white py-2 px-4 rounded-full shadow-lg border border-slate-100 flex items-center gap-2"
        >
          <Wifi class="h-4 w-4 text-blue-500" />
          <span class="text-xs font-bold text-slate-700">Señal Activa</span>
        </div>
      </div>
    </div>
  </div>
</section>
