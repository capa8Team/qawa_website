---
import { Droplet } from '@lucide/astro';
---

<footer class="bg-slate-900 border-t border-slate-800 py-12 text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">

    <!-- Logo y Copyright a la izquierda -->
    <div class="flex flex-col items-center md:items-start gap-4">
      <div class="flex items-center gap-2">
        <div class="bg-blue-600 p-2 rounded-lg">
          <Droplet class="text-white h-5 w-5" />
        </div>
        <span class="text-lg font-bold text-white tracking-tight">Q<span class="text-emerald-400">Awa</span></span>
      </div>
      <p class="text-sm text-slate-400">
        © 2026 QAwa por Untitled SpA. Todos los derechos reservados.
      </p>
    </div>

    <!-- Enlaces a la derecha -->
    <div class="flex flex-wrap justify-center gap-8 text-sm font-medium text-slate-300">
      <a href="/about-us/" class="hover:text-white transition-colors">Sobre Nosotros</a>
      <a href="/privacy/" class="hover:text-white transition-colors">Políticas de Privacidad</a>
      <a href="/terms/" class="hover:text-white transition-colors">Términos y Condiciones</a>
    </div>

  </div>
</footer>
